CG1_Poker_Project/
│
├── assets/                  # All your visual data goes here
│   ├── models/              # .obj files (poker_table.obj, chair.obj, casino.obj)
│   └── textures/            # .jpg/.png files (wood.jpg, felt.png, street.jpg)
│
├── shaders/                 # Your GLSL shader programs (worth bonus points!)
│   ├── basic.vert           # Vertex shader for geometry
│   ├── basic.frag           # Fragment shader for colors/textures
│   ├── light.vert           # (Optional) specific shader for lighting
│   └── light.frag
│
├── src/                     # Your actual engine/game code
│   ├── main.c               # Window creation, main loop, and spacebar input
│   ├── matrix.c             # The math you are currently testing
│   ├── vector.c             # Vector math
│   ├── camera.c             # LookAt and Perspective math
│   ├── obj_loader.c         # Code to read your .obj files
│   └── texture_loader.c     # Code using stb_image.h to load images
│
├── include/                 # Header files (optional, but good practice)
│   ├── matrix.h
│   ├── vector.h
│   ├── camera.h
│   ├── obj_loader.h
│   ├── texture_loader.h
│   └── stb_image.h          # The one external library you are allowed to use
│
├── tests/                   # Your custom test framework (what we fixed earlier)
│   ├── test_framework.c
│   ├── test_matrix.c
│   └── ... (all other test files)
│
└── README.md                # REQUIRED: Team names, sources, controls [cite: 20, 28, 51]
